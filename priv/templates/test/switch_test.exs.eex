defmodule <%= @component_namespace %>.SwitchTest do
  use ExUnit.Case, async: true

  import Phoenix.LiveViewTest
  import Phoenix.Component

  alias <%= @component_namespace %>.Switch

  # `switch` renders a checkbox input (role="switch") bound to a Phoenix form field,
  # so the smoke test supplies one rather than relying on introspection.
  defp form_field do
    Phoenix.Component.to_form(%{"notifications" => "true"}, as: :user)[:notifications]
  end

  describe "switch/1" do
    test "renders a switch bound to a form field" do
      assigns = %{field: form_field()}
      html = rendered_to_string(~H"<Switch.switch field={@field} />")
      assert html =~ ~s(type="checkbox")
      assert html =~ ~s(role="switch")
      assert html =~ ~s(name="user[notifications]")
    end

    test "renders every variant" do
      for variant <- ~w(solid outline ghost) do
        assigns = %{field: form_field(), variant: variant}
        html = rendered_to_string(~H"<Switch.switch field={@field} variant={@variant} />")
        assert html =~ ~s(role="switch")
      end
    end

    test "renders every color" do
      for color <- ~w(neutral primary secondary success danger warning info) do
        assigns = %{field: form_field(), color: color}
        html = rendered_to_string(~H"<Switch.switch field={@field} color={@color} />")
        assert html =~ ~s(role="switch")
      end
    end

    test "renders every size" do
      for size <- ~w(xs sm md lg xl) do
        assigns = %{field: form_field(), size: size}
        html = rendered_to_string(~H"<Switch.switch field={@field} size={@size} />")
        assert html =~ ~s(role="switch")
      end
    end
  end
end
