# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# ExCoveralls coverage reports
/coverage/
coverage.json
excoveralls.json

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
pulsar-*.tar

# Dialyzer PLT files (built locally and in CI)
/priv/plts/
*.plt
*.plt.hash

# Temporary files, for example, from tests.
/tmp/

# Claude Code configuration and cache
/.claude/
.claude/settings.local.json

# Playwright browser automation cache
/.playwright-mcp/
*.png

# Generated assets (should be built, not committed)
/priv/static/assets/

# ElixirLS language server
/.elixir_ls/

# Editor artifacts
.DS_Store
*.swp
*.swo

# Environment files
.env
.env.local
.expert/

# Dev app build artifacts (generated by `mix tailwind dev_app` / `mix esbuild dev_app`)
/test/support/dev_app/priv/static/
/test/support/dev_app/assets/css/theme.css
/test/support/dev_app/assets/node_modules/
/docs/superpowers/
